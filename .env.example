# 环境变量配置文件（不要提交到Git！）
# 复制此文件为 .env 并填入实际值

# 测试环境 (dev / test / prod)
TEST_ENV=test

# 服务地址（替换为实际测试环境地址）
BASE_URL=http://your-test-server

# 超时设置（秒）
TIMEOUT=30

# 日志级别 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# ---- 自定义配置（CFG_ 前缀自动映射） ----
# 格式: CFG_<KEY>=<value>，双下划线表示嵌套层级
# 例如:
#   CFG_DATABASE__HOST=localhost       -> config.get('database.host')
#   CFG_DATABASE__PORT=3306            -> config.get('database.port')
