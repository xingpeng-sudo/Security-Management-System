{
  "defaults": {
    "expected": {
      "http_status": 200,
      "code": 500
    }
  },
  "test_cases": [
    {
      "case_id": "TC_REG_001",
      "case_name": "正常注册-完整必填字段",
      "description": "使用全部必填字段且数据合法，验证注册成功并返回account和password",
      "priority": "P0",
      "data": {
        "supplierName": "测试公司_正常_{{timestamp_short}}",
        "legalRepresentative": "{{name}}",
        "businessLicenseNo": "91110000MA00{{random}}",
        "blIssuingAuthority": "北京市市场监督管理局",
        "blStartDate": "2024-01-01",
        "blEndDate": "2034-01-01",
        "contactsName": "{{name}}",
        "contactsPhone": "{{mobile}}",
        "bussinessType": "short_jx",
        "isSelfAccess": "0"
      },
      "expected": {
        "code": 0,
        "msg_contains": "通过审核"
      }
    },
    {
      "case_id": "TC_REG_002",
      "case_name": "正常注册-15位营业执照号",
